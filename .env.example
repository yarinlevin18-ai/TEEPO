# Frontend environment variables for TEEPO (Next.js).
# Copy to `.env.local` and fill in values.

# Backend URL used by the frontend.
NEXT_PUBLIC_API_URL=http://localhost:5000

# Display name of the university shown in the UI (headings, legal pages,
# academic advisor subtitle). If empty, the UI falls back to
# "האוניברסיטה שלך". Set per-deploy to match the student's school.
# Example: NEXT_PUBLIC_UNIVERSITY_NAME=אוניברסיטת בן-גוריון בנגב
NEXT_PUBLIC_UNIVERSITY_NAME=

# Supabase — needed for auth.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000

# Dev-only auth bypass. Set to "true" in your local .env.local to skip
# Google sign-in during development — /dashboard renders with a fake user.
# This flag is hard-guarded: it refuses to activate when NODE_ENV=production,
# so even if it leaks into a build it cannot disable auth in production.
# NEXT_PUBLIC_DEV_BYPASS_AUTH=true
