{
  "manifest_version": 3,
  "name": "BGU Study Organizer",
  "version": "1.0",
  "description": "מסנכרן את חשבון ה-BGU שלך עם אפליקציית הלמידה",
  "permissions": ["cookies", "tabs", "storage"],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
