{
  "manifest_version": 3,
  "name": "TEEPO",
  "version": "1.1",
  "description": "TEEPO — מסנכרן את חשבון ה-Moodle של האוניברסיטה עם מערכת הלימודים",
  "permissions": ["cookies", "tabs", "storage", "scripting", "activeTab"],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
