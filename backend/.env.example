ANTHROPIC_API_KEY=sk-ant-...
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key
SUPABASE_ANON_KEY=your-anon-key
FLASK_SECRET_KEY=your-secret-key
FLASK_ENV=development
CLAUDE_MODEL=claude-sonnet-4-6
ORCHESTRATOR_PATH=C:/Users/משתמש/OneDrive/Desktop/AI/Agents/Agents/orchestrator

# --- University / LMS configuration ---------------------------------------
# Configure these to point TEEPO at your university's Moodle + portal.
# Leave empty to disable the Moodle/Portal sync features.

# Display name shown in the UI (e.g., "אוניברסיטת בן-גוריון בנגב").
# Also exposed to the frontend via NEXT_PUBLIC_UNIVERSITY_NAME.
UNIVERSITY_NAME=

# Base URL of the Moodle instance, no trailing slash.
# Example: https://moodle.bgu.ac.il/moodle
MOODLE_URL=

# Primary student portal (grades / registration). Optional.
# Example: https://bgu4u22.bgu.ac.il
PORTAL_URL=

# Legacy portal URL, if your university still runs one. Optional.
# Example: https://my.bgu.ac.il
PORTAL_URL_OLD=

# Comma-separated allowlist of hostnames the scraper is allowed to touch.
# If empty, it's derived from MOODLE_URL / PORTAL_URL / PORTAL_URL_OLD.
# Example: moodle.bgu.ac.il,my.bgu.ac.il,bgu4u22.bgu.ac.il
UNIVERSITY_ALLOWED_DOMAINS=

# Credentials for the personal university account used by the scraper.
# BGU_USERNAME / BGU_PASSWORD are still read as a fallback for existing deploys.
UNIVERSITY_USERNAME=
UNIVERSITY_PASSWORD=

# University metadata (faculties, academic calendar, leadership, awards) lives
# in the repo at `data/university-info.json` and is imported at build time.
# To deploy for a different university, edit that file before building —
# its schema is generic, only the values are institution-specific.
